{
  "name": "Fishbone",
  "scopeName": "source.svs",
  "patterns": [
    {
      "name": "comment.block.svs",
      "begin": "/\\*",
      "end": "\\*/"
    },
    {
      "name": "comment.line.double-slash.svs",
      "match": "//.*$"
    },
    { "name": "keyword.control.svs", "match": "\\b(let|if|else|while|foreach|in|func|return|break|continue|import|and|or|xor|not)\\b" },
    { "name": "constant.language.svs", "match": "\\b(true|false)\\b" },
    { "name": "string.quoted.double.svs", "begin": "\"", "end": "\"" },
    { "name": "constant.numeric.svs", "match": "\\b\\d+(\\.\\d+)?\\b" },
    { "name": "entity.name.function.svs", "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()" }
  ]
}
