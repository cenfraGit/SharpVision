<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:AvaloniaEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             xmlns:local="clr-namespace:SharpGUI.Views.Editor"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SharpGUI.Views.Editor.ScriptEditorView"
             x:DataType="local:ScriptEditorVM">
  <AvaloniaEdit:TextEditor Name="Editor"
                           Background="#1E1E1E"
                           Foreground="#D4D4D4"
                           ShowLineNumbers="True"
                           FontFamily="{StaticResource CascadiaCode}"
                           Document="{Binding ScriptDocument, Mode=TwoWay}"/>
</UserControl>
